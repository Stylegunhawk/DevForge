# ------------------------------------------------------------------------------
# DevForge API-Only Environment Configuration
# ------------------------------------------------------------------------------
# This file contains ALL variables defined in `src/core/config.py`.
# Variables that are not typically required or are explicitly bypassed in an 
# API-only deployment (no external DBs, no redis) are commented out at the bottom.
# ------------------------------------------------------------------------------

# Server Configuration
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3210,http://localhost:5173
LOG_LEVEL=INFO
ENVIRONMENT=development

# ------------------------------------------------------------------------------
# Ollama Configuration
# ------------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
# OLLAMA_API_KEY=your_api_key_here

# ------------------------------------------------------------------------------
# Model Selection
# ------------------------------------------------------------------------------
DEFAULT_MODEL=gemma-1b
SUPERVISOR_MODEL=gemma-1b
RAG_LOCAL_MODEL=gemma-1b
RAG_CLOUD_MODEL=gemma-1b
GITHUB_MODEL=gemma-1b
PREMIUM_MODEL=gemma-1b
EMBEDDING_MODEL=bge-m3

# ------------------------------------------------------------------------------
# Storage Configuration
# ------------------------------------------------------------------------------
# STORAGE_ROOT=./data/uploads/users
# FILE_BASE_URL=http://localhost:8000/static/uploads/users

# ------------------------------------------------------------------------------
# RAG Configuration
# ------------------------------------------------------------------------------
# VECTOR_BACKEND=chroma
# CHROMA_PERSIST_DIR=./data/chromadb
# CHROMA_COLLECTION=devforge_docs
# RAG_EMBED_MODEL=nomic-embed-text
# RAG_EMBED_MODEL_FALLBACK=bge-m3
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=50
# RAG_TOP_K=5
# RAG_SCORE_THRESHOLD=0.0


# ------------------------------------------------------------------------------
# GitOps Configuration
# ------------------------------------------------------------------------------
GITOPS_STORAGE=memory
GITOPS_ENABLE_FUZZY_SEARCH=true
GITOPS_FUZZY_THRESHOLD=0.85
GITOPS_ENABLE_COMMIT_GEN=true
GITOPS_ENABLE_WORKFLOWS=true
GITOPS_ENABLE_LOG_PARSING=true
GITOPS_ENABLE_ASYNC_JOBS=false
GITOPS_AUTO_CONFIRM=false
GITOPS_ENABLE_ROLLBACK=true
GITOPS_UNDO_WINDOW_MINUTES=30
GITOPS_REPO_CACHE_TTL=3600
GITOPS_LLM_TIMEOUT=10
GITOPS_SESSION_TTL=1800
GITOPS_JOB_CLEANUP_HOURS=24
GITOPS_AUTO_FIX_THRESHOLD=0.95
GITOPS_AUTO_FIX_TYPES=["format", "dependency_patch", "lint"]
MAX_SYNC_WORK_UNITS=50
WORK_UNIT_TIMEOUT_SECONDS=10

# ------------------------------------------------------------------------------
# Reranking Configuration
# ------------------------------------------------------------------------------
# ENABLE_RERANKING=true
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_SCORE_THRESHOLD=0.3
# VECTOR_SEARCH_CANDIDATES=30
# BOOST_FUNCTION=1.2
# BOOST_CLASS=1.15
# BOOST_IMPORT=1.0
# BOOST_TEXT=0.95

# ------------------------------------------------------------------------------
# Intent Classification & Query Expansion
# ------------------------------------------------------------------------------
# ENABLE_INTENT_CLASSIFICATION=true
# INTENT_RULE_BASED_THRESHOLD=1
# INTENT_LLM_FALLBACK=false
# INTENT_LLM_TIMEOUT=3
# DEFAULT_INTENT=code_search
# ENABLE_QUERY_EXPANSION=true
# EXPANSION_LLM_MODEL=gemma-1b
# EXPANSION_TIMEOUT=5

# ------------------------------------------------------------------------------
# Caching & Search Features
# ------------------------------------------------------------------------------
# ENABLE_QUERY_CACHE=true
# QUERY_CACHE_TTL=3600
# QUERY_CACHE_MAX_SIZE=1000
# ENABLE_HYBRID_SEARCH=true
# HYBRID_ALPHA=0.5
# BM25_INDEX_BATCH_SIZE=500
# ENABLE_SEMANTIC_CACHE=true
# SEMANTIC_CACHE_THRESHOLD=0.92
# SEMANTIC_CACHE_MAX_SIZE_PER_INTENT=100

# ------------------------------------------------------------------------------
# Code Graph Configuration
# ------------------------------------------------------------------------------
# ENABLE_CODE_GRAPH=true
# GRAPH_CONTEXT_DEPTH=2
# GRAPH_MAX_CONTEXT_CHUNKS=3

# ------------------------------------------------------------------------------
# EXPERIMENTAL: Cloud Deployment Gateway Feature
# ------------------------------------------------------------------------------
# GATEWAY_URL=http://localhost:8000/api/gateway

# ------------------------------------------------------------------------------
# OPTIONAL SERVICES (Commented out for API-Only Mode)
# ------------------------------------------------------------------------------

# GitHub Integration
# GITHUB_TOKEN=your_github_token_here
# GITHUB_USERNAME=your_username

# Qdrant Cloud (Alternative Vector DB to Chroma)
# QDRANT_URL=https://xxx.europe-west3-0.gcp.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# PostgreSQL (pgvector storage)
# POSTGRES_URL=postgresql://devforge:devforge_pass@postgres:5432/devforge
# PG_VECTOR_DIMENSION=768
# USE_PGVECTOR=false
# PGVECTOR_FALLBACK_TO_CHROMA=true
# DATABASE_URL=postgresql://devforge:devforge_pass@postgres:5432/devforge

# Redis (Caching / Background worker queues)
# REDIS_URL=redis://localhost:6379/0

# Celery (Background Tasks)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CELERY_TASK_SOFT_TIME_LIMIT=300
# CELERY_TASK_TIME_LIMIT=360

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id
JWT_SECRET=your-secret-key
