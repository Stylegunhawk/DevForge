{
  "identifier": "devforge",
  "name": "DevForge",
  "meta": {
    "author": "You",
    "version": "0.3.1",
    "description": "Local developer tools (data generation, RAG, and GitHub automation)"
  },
  "api": [
    {
      "name": "generate_data",
      "description": "Generate mock CSV/JSON data using Faker and Pandas.",
      "parameters": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "integer",
            "description": "Number of rows to generate",
            "minimum": 1,
            "maximum": 10000,
            "default": 10
          },
          "format": {
            "type": "string",
            "description": "Output format",
            "enum": ["json", "csv"],
            "default": "json"
          },
          "fields": {
            "type": "array",
            "description": "Optional custom fields (e.g., ['name','email','phone'])",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["rows"]
      },
      "call_mode": "prefer"
    },
    {
      "name": "retrieve_docs",
      "description": "Search documents using RAG (ChromaDB / Qdrant). Ingest documents and query them semantically.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "file_paths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional: Documents to ingest first (PDF, MD, TXT, DOCX)"
          },
          "top_k": {
            "type": "integer",
            "default": 5,
            "minimum": 1,
            "maximum": 50,
            "description": "Number of results to return"
          },
          "embed_model": {
            "type": "string",
            "enum": ["nomic-embed-text", "bge-m3"],
            "default": "nomic-embed-text",
            "description": "Embedding model to use"
          }
        },
        "required": ["query"]
      },
      "call_mode": "prefer"
    },
    {
      "name": "github_operation",
      "description": "Perform GitHub actions such as listing repositories, creating issues, committing files, and opening pull requests.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Natural language description of the GitHub action (e.g., 'list my repos', 'create issue in my-repo')"
          }
        },
        "required": ["query"]
      },
      "call_mode": "prefer"
    }
  ]
}
