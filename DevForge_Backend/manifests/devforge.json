{
  "identifier": "devforge",
  "name": "DevForge",
  "meta": {
    "author": "You",
    "version": "0.2.0",
    "description": "Local developer tools (data generation)"
  },
  "api": [
    {
      "name": "generate_data",
      "description": "Generate mock CSV/JSON data using Faker and Pandas.",
      "parameters": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "integer",
            "description": "Number of rows to generate",
            "minimum": 1,
            "maximum": 10000,
            "default": 10
          },
          "format": {
            "type": "string",
            "description": "Output format",
            "enum": ["json", "csv"],
            "default": "json"
          },
          "fields": {
            "type": "array",
            "description": "Optional custom fields (e.g., ['name','email','phone'])",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["rows"]
      },
      "call_mode": "prefer" 
    }
  ]
}
