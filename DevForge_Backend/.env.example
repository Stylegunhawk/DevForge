PORT=8000
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=gemma-1b
# Production: Set to your actual domain
CORS_ORIGINS=http://localhost:3010,http://localhost:3210,http://localhost:5173
LOG_LEVEL=info
ENVIRONMENT=development  # Use "production" when deploying
FILE_BASE_URL=http://localhost:8000/static/uploads
# REDIS_URL=redis://localhost:6379/0

# Database Configuration (Required for Full RAG Mode)
# POSTGRES_USER=devforge
# POSTGRES_PASSWORD=devforge123
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=devforge
# POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
CELERY_WORKERS=4



# Embedding Models (Phase 3)
EMBEDDING_PRIMARY=bge-m3           # Documents: 8K context, code-trained
EMBEDDING_FAST=nomic-embed-text    # Queries: Fast response
EMBEDDING_FALLBACK=embedding-gemma # Backup if needed

# Strategy
USE_HYBRID_EMBEDDINGS=true

source venv/bin/activate

.venv\Scripts\activate

python scripts/mcp_inspector.py -i


Test 1: With name (Lobe Chat format)
curl -X POST http://localhost:8000/api/gateway \
  -H "Content-Type: application/json" \
  -d '{
    "name": "generate_cheatsheet",
    "arguments": {
      "language": "python",
      "skill_level": "intermediate"
    }
  }'

Test 2: With apiName (MCP Inspector format)
curl -X POST http://localhost:8000/api/gateway \
  -H "Content-Type: application/json" \
  -d '{
    "apiName": "generate_cheatsheet",
    "arguments": {
      "language": "python",
      "skill_level": "intermediate"
    }
  }'


  tree -a \
  -I '.git|__pycache__|*.pyc|venv|.venv|env|.env|.pytest_cache|.tox|.mypy_cache|dist|build|*.egg-info|node_modules' \
  --dirsfirst \
  -o structure.txt

  uvicorn src.main:app --reload --reload-exclude data/uploads --port 8000

celery -A src.workers.celery_app worker --loglevel=info