# =============================================================================
# DevForge Backend Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8000
CORS_ORIGINS=http://localhost:3010,http://localhost:3210,http://localhost:5173
LOG_LEVEL=INFO
ENVIRONMENT=development  # Use "production" when deploying

# =============================================================================
# Ollama Configuration
# =============================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=  # Optional: if your Ollama instance requires authentication

# =============================================================================
# Model Configuration (Phase 1-3)
# =============================================================================
# Phase 1: Primary model for simple tasks
DEFAULT_MODEL=gpt-oss:20b-cloud

# Phase 2: Supervisor router model
SUPERVISOR_MODEL=gpt-oss:20b-cloud

# Phase 3: RAG models
RAG_LOCAL_MODEL=gpt-oss:20b-cloud
RAG_CLOUD_MODEL=gpt-oss:120b-cloud

# Phase 3: GitHub operations model
GITHUB_MODEL=gpt-oss:20b-cloud

# Phase 3: Premium reasoning model
PREMIUM_MODEL=deepseek-v3.1:671b-cloud

# Phase 3: Embedding model (legacy, kept for compatibility)
EMBEDDING_MODEL=bge-m3

# =============================================================================
# RAG Configuration (Phase 3)
# =============================================================================
VECTOR_BACKEND=postgres  # Options: chroma, postgres
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION=devforge_docs
RAG_EMBED_MODEL=nomic-embed-text
RAG_EMBED_MODEL_FALLBACK=bge-m3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.0

# =============================================================================
# Storage Configuration
# =============================================================================
STORAGE_ROOT=./data/uploads/users
FILE_BASE_URL=http://localhost:8000/static/uploads

# =============================================================================
# Qdrant Cloud Configuration (Phase 3.1b)
# =============================================================================
QDRANT_URL=  # e.g., https://xxx.europe-west3-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=devforge_docs

# =============================================================================
# GitHub Integration (Phase 3)
# =============================================================================
# NOTE: GITHUB_TOKEN is legacy and should not be used in production.
# Tokens should be provided from the frontend via the github_token parameter.
# This variable is only kept for backward compatibility during development.
GITHUB_TOKEN=  # Legacy: Do not use in production
GITHUB_USERNAME=  # Optional: for display purposes

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=  # Optional: legacy database URL
POSTGRES_URL=postgresql://user:password@host:port/database

# =============================================================================
# GitOps Configuration (v0.8)
# =============================================================================
GITOPS_STORAGE=memory  # Options: memory, redis, postgres
GITOPS_ENABLE_FUZZY_SEARCH=true
GITOPS_FUZZY_THRESHOLD=0.85
GITOPS_ENABLE_COMMIT_GEN=true
GITOPS_ENABLE_WORKFLOWS=true
GITOPS_ENABLE_LOG_PARSING=true
GITOPS_ENABLE_ASYNC_JOBS=true
GITOPS_AUTO_CONFIRM=false
GITOPS_ENABLE_ROLLBACK=true
GITOPS_UNDO_WINDOW_MINUTES=30
GITOPS_REPO_CACHE_TTL=3600
GITOPS_LLM_TIMEOUT=10
GITOPS_SESSION_TTL=1800
GITOPS_JOB_CLEANUP_HOURS=24

# =============================================================================
# Redis Configuration (required for GITOPS_STORAGE=redis)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Auto-fix Policy (CI Diagnostics)
# =============================================================================
GITOPS_AUTO_FIX_THRESHOLD=0.95
GITOPS_AUTO_FIX_TYPES=format,dependency_patch,lint

# =============================================================================
# Work Unit Configuration
# =============================================================================
MAX_SYNC_WORK_UNITS=50
WORK_UNIT_TIMEOUT_SECONDS=10

# =============================================================================
# Celery Configuration (Phase 10.1)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=360

# =============================================================================
# pgvector Configuration (Phase 10.1)
# =============================================================================
PG_VECTOR_DIMENSION=768
USE_PGVECTOR=false
PGVECTOR_FALLBACK_TO_CHROMA=true

# =============================================================================
# Code Graph Configuration (Phase 10.1)
# =============================================================================
ENABLE_CODE_GRAPH=true
GRAPH_CONTEXT_DEPTH=2
GRAPH_MAX_CONTEXT_CHUNKS=3

# =============================================================================
# Reranking Configuration (Phase 11)
# =============================================================================
ENABLE_RERANKING=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_SCORE_THRESHOLD=0.3
VECTOR_SEARCH_CANDIDATES=30

# =============================================================================
# Code-aware Boosting (Phase 11 Day 3)
# =============================================================================
BOOST_FUNCTION=1.2
BOOST_CLASS=1.15
BOOST_IMPORT=1.0
BOOST_TEXT=0.95

# =============================================================================
# Query Cache Configuration (Phase 11.2)
# =============================================================================
ENABLE_QUERY_CACHE=true
QUERY_CACHE_TTL=3600
QUERY_CACHE_MAX_SIZE=1000

# =============================================================================
# Hybrid Search Configuration (Phase 11.2)
# =============================================================================
ENABLE_HYBRID_SEARCH=true
HYBRID_ALPHA=0.5
BM25_INDEX_BATCH_SIZE=500

# =============================================================================
# Intent Classification Configuration (Phase 12A Day 1)
# =============================================================================
ENABLE_INTENT_CLASSIFICATION=true
INTENT_RULE_BASED_THRESHOLD=1
INTENT_LLM_FALLBACK=false
INTENT_LLM_TIMEOUT=3
DEFAULT_INTENT=code_search

# =============================================================================
# Query Expansion Configuration (Phase 12A Day 3-4)
# =============================================================================
ENABLE_QUERY_EXPANSION=true
EXPANSION_LLM_MODEL=gpt-oss:20b-cloud
EXPANSION_TIMEOUT=5

# =============================================================================
# Semantic Cache Configuration (Phase 12A Day 5-6)
# =============================================================================
ENABLE_SEMANTIC_CACHE=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_SIZE_PER_INTENT=100

# =============================================================================
# Gateway Configuration
# =============================================================================
GATEWAY_URL=  # Optional: override default gateway URL