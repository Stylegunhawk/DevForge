
# ===============================
# Core App
# ===============================
APP_URL=http://localhost:3010
NEXT_PUBLIC_SERVICE_MODE=client
NEXT_DISABLE_STATIC_GENERATION=1
NEXT_TELEMETRY_DISABLED=1

# ===============================
# LLM (Ollama only)
# ===============================
OLLAMA_PROXY_URL=http://localhost:11434

OLLAMA_MODEL_LIST=gpt-oss:20b-cloud,gpt-oss:120b-cloud,deepseek-r1:8b,qwen3:4b,gemma3:1b,qwen3-coder:480b-cloud,deepseek-v3.1:671b-cloud,qwen3-vl:235b-cloud

GOOGLE_API_KEY=AIzaSyDslBPIaktHMYqJMiHl1ioLf4zwNbAoaKs
# ===============================
# Disable ALL Auth
# ===============================
NEXT_PUBLIC_ENABLE_NEXT_AUTH=0
NEXTAUTH_SECRET=disabled
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
ENABLE_OAUTH_SSO=0
KEY_VAULTS_SECRET=disabled

# ===============================
# Disable Marketplace / Agents
# ===============================
NEXT_PUBLIC_ENABLE_MARKET=false
NEXT_PUBLIC_ENABLE_PLUGINS=false
AGENTS_INDEX_URL=
PLUGINS_INDEX_URL=
PLUGIN_MARKET_INDEX_URL=

# ===============================
# Disable RAG / Database
# ===============================
NEXT_PUBLIC_ENABLE_RAG=false
NEXT_PUBLIC_ENABLE_KNOWLEDGE_BASE=false
DATABASE_URL=

# ===============================
# Disable Analytics & Telemetry
# ===============================
ENABLE_TELEMETRY=0
POSTHOG_KEY=
ENABLE_VERCEL_ANALYTICS=0
UMAMI_WEBSITE_ID=
GOOGLE_ANALYTICS_MEASUREMENT_ID=
REACT_SCAN_MONITOR_API_KEY=

# ===============================
# Disable Error Tracking
# ===============================
NEXT_PUBLIC_ENABLE_SENTRY=0
NEXT_PUBLIC_SENTRY_DSN=

# ===============================
# Disable File Uploads (S3)
# ===============================


# ===============================
# Performance
# ===============================
NODE_OPTIONS=--max-old-space-size=4096
