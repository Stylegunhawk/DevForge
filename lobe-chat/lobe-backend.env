# Postgres
DATABASE_URL=postgres://postgres:lobepass@host.docker.internal:5432/postgres

# S3 / MinIO
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://host.docker.internal:9000
S3_BUCKET=lobe-chat-files
S3_REGION=us-east-1
S3_ENABLE_PATH_STYLE=1
S3_SET_ACL=0
S3_PUBLIC_DOMAIN=http://localhost:9000

# Embedding for Knowledge Base (RAG)
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
DEFAULT_FILES_CONFIG=embedding_model=openai/embedding-text-3-small

# Auto chunk + embed on upload
CHUNKS_AUTO_EMBEDDING=1
CHUNKS_AUTO_GEN_METADATA=1
